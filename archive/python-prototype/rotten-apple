# Xen hypervisor command line. Conservative defaults that boot anywhere
# Xen can boot at all; aggressive features are opt-in via CLI flags.
#
# Why this is conservative:
# - `iommu=on` enables IOMMU when available, gracefully degrades otherwise.
#   `iommu=force,strict` would panic the hypervisor on any host without a
#   working IOMMU (real BIOSes with VT-d disabled, nested KVM without IOMMU
#   passthrough, etc). For the v0.x lift we want "boot first, optimize later."
# - dom0 defaults to classic PV mode. `dom0=pvh` is faster but requires
#   PVH-on-VMX features that aren't always available in nested virt
#   environments.
#
# Opt-in flags add the aggressive bits:
#   --iommu-force  : append ',force,strict' (real-hardware passthrough)
#   --dom0-pvh     : append ' dom0=pvh' (modern dom0 mode)
XEN_CMDLINE_BASE = (
    "dom0_mem={dom0_mem},max:{dom0_mem} "
    "dom0_max_vcpus={dom0_vcpus} "
    "iommu=on"
)

# Back-compat alias used by older code paths in this file.
XEN_CMDLINE_TEMPLATE = XEN_CMDLINE_BASE


def build_xen_cmdline(dom0_mem: str, dom0_vcpus: str,
                      iommu_force: bool = False,
                      dom0_pvh: bool = False,
                      serial_console: bool = False) -> str:
    """Compose the Xen hypervisor command line from base + opt-in flags."""
    parts = [XEN_CMDLINE_BASE.format(dom0_mem=dom0_mem, dom0_vcpus=dom0_vcpus)]
    if iommu_force:
        parts[0] = parts[0].replace("iommu=on", "iommu=force,strict")
    if dom0_pvh:
        parts.append("dom0=pvh")
    if serial_console:
        # Send Xen and dom0 console output to ttyS0 (com1). Critical for
        # nested-VM debugging where there is no VGA.
        parts.extend(["console=com1,vga", "com1=115200,8n1"])
    return " ".join(parts)

