# State

@dataclass
class LiftState:
    version: str = VERSION
    lifted: bool = False
    lift_timestamp: Optional[str] = None
    backup_dir: Optional[str] = None
    xen_packages_installed: list[str] = field(default_factory=list)
    xen_entry_title: Optional[str] = None
    xen_default_path: Optional[str] = None     # full GRUB_DEFAULT path
    grub_default_before: Optional[str] = None
    show_menu_pending: bool = False            # set by --show-grub-menu, cleared by finalize
    firstboot_autostart_for: Optional[str] = None  # username we installed autostart for
    notes: list[str] = field(default_factory=list)

def load_state() -> LiftState:
    if not STATE_FILE.exists():
        return LiftState()
    try:
        d = json.loads(STATE_FILE.read_text())
        return LiftState(**d)
    except Exception as e:
        log.warning("state file unreadable (%s); starting fresh", e)
        return LiftState()

def save_state(s: LiftState) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(asdict(s), indent=2) + "\n")

# ---------------------------------------------------------------------------
# Detection

@dataclass
class Detection:
    distro_id: str
    distro_version: str
    is_uefi: bool
    secure_boot: str  # "enabled", "disabled", "unknown"
    cpu_count: int
    mem_total_kb: int
    has_intel_iommu: bool
    has_amd_iommu: bool
    iommu_in_cmdline: bool
    nvidia_proprietary: bool
    xen_already_installed: bool
    running_under_xen: bool
    grub_default_raw: Optional[str]
    kernel: str
    arch: str
    boot_free_mb: int = 0           # /boot free space in MB
    root_free_mb: int = 0           # / free space in MB
    initramfs_path: Optional[str] = None
    initramfs_size_mb: int = 0
    warnings: list[str] = field(default_factory=list)
    blockers:  list[str] = field(default_factory=list)

def detect() -> Detection:
    # Distro
    distro_id = "unknown"; distro_version = "unknown"
    if Path("/etc/os-release").exists():
        for line in Path("/etc/os-release").read_text().splitlines():
            if line.startswith("ID="):           distro_id      = line.split("=",1)[1].strip().strip('"')
            if line.startswith("VERSION_ID="):   distro_version = line.split("=",1)[1].strip().strip('"')

    # UEFI?
    is_uefi = Path("/sys/firmware/efi").exists()

    # Secure Boot
    sb = "unknown"
    if have("mokutil"):
        try:
            r = run(["mokutil", "--sb-state"], capture=True, check=False)
            txt = (r.stdout or "") + (r.stderr or "")
            if "SecureBoot enabled" in txt:    sb = "enabled"
            elif "SecureBoot disabled" in txt: sb = "disabled"
        except Exception:
            pass

    # CPU/mem
    cpu_count = os.cpu_count() or 1
    mem_kb = 0
    if Path("/proc/meminfo").exists():
        for line in Path("/proc/meminfo").read_text().splitlines():
            if line.startswith("MemTotal:"):
                mem_kb = int(line.split()[1])
                break

    # IOMMU
    has_intel = False; has_amd = False
    if Path("/proc/cpuinfo").exists():
        cpu = Path("/proc/cpuinfo").read_text()
        has_intel = "GenuineIntel" in cpu
        has_amd   = "AuthenticAMD" in cpu
    cmdline = ""
    if Path("/proc/cmdline").exists():
        cmdline = Path("/proc/cmdline").read_text()
    iommu_on = ("intel_iommu=on" in cmdline) or ("amd_iommu=on" in cmdline) or ("iommu=pt" in cmdline)

    # NVIDIA proprietary?
    nv_proprietary = False
    try:
        if have("lsmod"):
            mods = out(["lsmod"], check=False)
            nv_proprietary = bool(re.search(r"^nvidia\b", mods, re.M))
    except Exception:
        pass

    # Xen hypervisor present? Match only the real hypervisor packages, not
    # GRUB's xen-loader support (`grub-xen-*`) or runtime libs (`libxen*`),
    # which are pre-installed on stock Ubuntu and don't mean Xen is active.
    xen_pkgs = False
    if have("dpkg"):
        r = run(["dpkg", "-l"], capture=True, check=False)
        xen_pkgs = bool(re.search(
            r"^ii\s+(xen-system|xen-hypervisor)-",
            r.stdout or "", re.M,
        ))

    # Running under Xen right now?
    running_xen = Path("/proc/xen").is_dir() or "xen" in cmdline

    # GRUB default
    gd = None
    if GRUB_DEFAULTS.exists():
        for line in GRUB_DEFAULTS.read_text().splitlines():
            if line.startswith("GRUB_DEFAULT="):
                gd = line.split("=", 1)[1].strip()
                break

    # Kernel + arch
    kernel = os.uname().release
    arch   = os.uname().machine

    # /boot and / free space (matters for apt install + initramfs regen)
    def _free_mb(path: str) -> int:
        try:
            st = os.statvfs(path)
            return (st.f_bavail * st.f_frsize) // (1024 * 1024)
        except FileNotFoundError:
            return 0
    boot_free_mb = _free_mb("/boot")
    root_free_mb = _free_mb("/")

    # Existing initramfs file (we'll back it up before regenerating)
    initramfs_path: Optional[str] = None
    initramfs_size_mb = 0
    candidate = Path(f"/boot/initrd.img-{kernel}")
    if candidate.exists():
        initramfs_path = str(candidate)
        initramfs_size_mb = candidate.stat().st_size // (1024 * 1024)

    d = Detection(
        distro_id=distro_id, distro_version=distro_version,
        is_uefi=is_uefi, secure_boot=sb,
        cpu_count=cpu_count, mem_total_kb=mem_kb,
        has_intel_iommu=has_intel, has_amd_iommu=has_amd,
        iommu_in_cmdline=iommu_on,
        nvidia_proprietary=nv_proprietary,
        xen_already_installed=xen_pkgs,
        running_under_xen=running_xen,
        grub_default_raw=gd,
        kernel=kernel, arch=arch,
        boot_free_mb=boot_free_mb,
        root_free_mb=root_free_mb,
        initramfs_path=initramfs_path,
        initramfs_size_mb=initramfs_size_mb,
    )

    if arch != "x86_64":
        d.blockers.append(f"unsupported architecture: {arch} (need x86_64)")
    if distro_id not in ("ubuntu", "debian"):
        d.warnings.append(f"untested distro: {distro_id} {distro_version}")
    if not is_uefi:
        d.warnings.append("BIOS/legacy boot detected; lift only tested on UEFI")
    if sb == "enabled":
        d.warnings.append("Secure Boot is enabled; Xen on Ubuntu is signed but "
                          "MOK enrollment may be required on first boot")
    if mem_kb and mem_kb < 16 * 1024 * 1024:
        d.warnings.append(f"low RAM ({mem_kb//1024} MB); guests will be tight")
    if nv_proprietary:
        d.warnings.append("NVIDIA proprietary driver loaded; dom0 + nvidia.ko "
                          "can have display issues — keep the bare-metal GRUB "
                          "entry visible during first lift")
    if xen_pkgs and not running_xen:
        d.warnings.append("Xen packages already installed but not booted via "
                          "Xen; lift will reuse them")
    if running_xen:
        d.blockers.append("system is already running under Xen; nothing to lift")

    # Disk space — Xen install + initramfs regen + grub regen needs headroom.
    # ~80 MB on /boot is roughly the worst case observed (xen.gz ~5 MB,
    # new initramfs may grow +20 MB, GRUB cfg is small). Round up to 128 MB
    # as a hard floor for safety, 50 MB as a warning threshold.
    if d.boot_free_mb < 128:
        if d.boot_free_mb < 50:
            d.blockers.append(
                f"/boot has only {d.boot_free_mb} MB free; need ≥128 MB. "
                f"Free space first (e.g. apt autoremove old kernels)."
            )
        else:
            d.warnings.append(
                f"/boot is tight ({d.boot_free_mb} MB free); recommend ≥128 MB."
            )
    # / for apt cache (downloaded packages stage in /var/cache/apt). ~200 MB
    # is plenty for xen-system-amd64 + deps.
    if d.root_free_mb < 500:
        d.warnings.append(
            f"/ has only {d.root_free_mb} MB free; apt may struggle. "
            f"Recommend ≥1 GB free."
        )

    if not d.initramfs_path:
        d.warnings.append(
            f"no initramfs found for kernel {kernel}; backup step will be "
            f"skipped (recovery from a broken initramfs would require a USB "
            f"live-media boot)."
        )

    return d

# ---------------------------------------------------------------------------
# GRUB manipulation

def list_menuentries(cfg_text: str) -> list[str]:
    """Extract menuentry titles from a grub.cfg blob (top-level + nested)."""
    out = []
    for m in re.finditer(r"^\s*menuentry\s+'([^']+)'", cfg_text, re.M):
        out.append(m.group(1))
    return out

def find_xen_path(cfg_text: str) -> Optional[str]:
    """
    Return the GRUB_DEFAULT-style path to the Xen menuentry, e.g.
    'Ubuntu, with Xen hypervisor' for a top-level entry, or
    'Advanced options>Ubuntu, with Xen' for a submenu-nested one.
    Skips entries with 'recovery' in their title.

    Tracks brace depth and submenu nesting. Brace counting on each line is
    a heuristic that works for grub.cfg as generated by `update-grub`; it
    will be confused by braces inside string literals in menuentry bodies,
    but that pattern doesn't occur in stock Ubuntu output.
    """
    submenu_stack: list[tuple[int, str]] = []   # (depth_at_open, name)
    pending_submenu: Optional[str] = None       # submenu seen, awaiting '{'
    depth = 0

    for line in cfg_text.splitlines():
        s = line.strip()

        m_entry = re.match(r"menuentry\s+'([^']+)'", s)
        m_sub   = re.match(r"submenu\s+'([^']+)'", s)

        if m_entry:
            title = m_entry.group(1)
            if "xen" in title.lower() and "recovery" not in title.lower():
                names = [n for _, n in submenu_stack] + [title]
                return ">".join(names)
        elif m_sub:
            pending_submenu = m_sub.group(1)

        # Walk brace tokens left-to-right so submenu/brace pairing is correct
        # even when '{' is on the same line as `submenu '...'`.
        for ch in s:
            if ch == '{':
                depth += 1
                if pending_submenu is not None:
                    submenu_stack.append((depth, pending_submenu))
                    pending_submenu = None
            elif ch == '}':
                if submenu_stack and submenu_stack[-1][0] == depth:
                    submenu_stack.pop()
                depth -= 1
    return None

# Back-compat alias (older callers)
find_xen_entry = find_xen_path

def patch_grub_defaults(
    text: str,
    xen_cmdline: str,
    xen_default_path: str,
    show_menu: bool = False,
    dom0_serial_console: bool = False,
) -> str:
    """
    Insert (or replace) our managed block in /etc/default/grub.

    We never edit existing user lines in place. We append a managed block at
    the end, inside MARKER_BEGIN/END, overriding GRUB_DEFAULT and adding
    GRUB_CMDLINE_XEN_DEFAULT. If show_menu=True, also override
    GRUB_TIMEOUT_STYLE and GRUB_TIMEOUT so the menu is visible for ~5s — used
    on the first lifted boot so the user can verify both entries are present.
    `finalize` rewrites the block with show_menu=False to re-hide the menu.

    `unlift` strips the entire block, restoring the user's original defaults.
    """
    text = strip_managed_block(text)
    block_lines = [
        MARKER_BEGIN,
        f'GRUB_DEFAULT="{xen_default_path}"',
        f'GRUB_CMDLINE_XEN_DEFAULT="{xen_cmdline}"',
    ]
    if show_menu:
        block_lines += [
            'GRUB_TIMEOUT_STYLE=menu',
            'GRUB_TIMEOUT=5',
        ]
    if dom0_serial_console:
        # Xen-only override — the bare-metal entry keeps its original cmdline.
        # `console=hvc0` makes dom0's kernel use the Xen virtual console,
        # which Xen then routes to com1 (the QEMU serial we're logging).
        # `quiet` is dropped intentionally: in dev/diagnostic mode we want
        # to see the kernel's PCI / virtio / xen-blkfront enumeration logs.
        block_lines.append(
            'GRUB_CMDLINE_LINUX_XEN_REPLACE_DEFAULT='
            '"console=hvc0 earlyprintk=xen ignore_loglevel"'
        )
    block_lines.append(MARKER_END)
    if not text.endswith("\n"):
        text += "\n"
    return text + "\n".join(block_lines) + "\n"

def strip_managed_block(text: str) -> str:
    pattern = re.compile(
        re.escape(MARKER_BEGIN) + r".*?" + re.escape(MARKER_END) + r"\n?",
        re.DOTALL,
    )
    return pattern.sub("", text)

# ---------------------------------------------------------------------------
# Backup helpers

def install_firstboot_autostart(target_user: str) -> Optional[str]:
    """
    Install the first-boot verify autostart under target_user's $HOME.
    Returns the username on success, or None on failure (logged).

    We resolve the user's home directory via getpwnam so this works whether
    `lift` was invoked via `sudo` (target_user = $SUDO_USER) or directly.
    """
    try:
        import pwd
        pw = pwd.getpwnam(target_user)
    except KeyError:
        log.warning("user '%s' not found; skipping firstboot autostart", target_user)
        return None

    home = Path(pw.pw_dir)
    cfg = home / ".config" / "rotten-apple"
    autostart = home / ".config" / "autostart"
    cfg.mkdir(parents=True, exist_ok=True)
    autostart.mkdir(parents=True, exist_ok=True)

    rotten_apple_path = os.path.realpath(sys.argv[0])
    helper_path = cfg / FIRSTBOOT_HELPER_NAME
    desktop_path = autostart / FIRSTBOOT_DESKTOP_NAME

    helper_path.write_text(FIRSTBOOT_HELPER.format(
        rotten_apple_path=rotten_apple_path,
        desktop_name=FIRSTBOOT_DESKTOP_NAME,
    ))
    helper_path.chmod(0o755)

    desktop_path.write_text(FIRSTBOOT_DESKTOP.format(helper_path=helper_path))
    desktop_path.chmod(0o644)

    # chown everything to the target user so the helper can self-delete.
    for p in (cfg, helper_path, autostart, desktop_path):
        try:
            os.chown(p, pw.pw_uid, pw.pw_gid)
        except PermissionError:
            log.warning("could not chown %s to %s; firstboot may not run", p, target_user)
            return None

    log.info("installed firstboot autostart for user %s", target_user)
    return target_user

def backup_files(paths: list[Path]) -> Path:
    ts = time.strftime("%Y%m%dT%H%M%S")
    dst = BACKUP_DIR / ts
    dst.mkdir(parents=True, exist_ok=True)
    for p in paths:
        if not p.exists():
            continue
        rel = str(p).lstrip("/")
        target = dst / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(p, target)
        log.info("backed up %s -> %s", p, target)
    return dst

