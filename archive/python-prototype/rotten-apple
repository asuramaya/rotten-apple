# ---------------------------------------------------------------------------
# Wizard UI helpers (plain text + ANSI colours; no third-party deps)

class _C:
    """ANSI sequences. Empty strings when stdout is not a TTY."""
    @staticmethod
    def _on() -> bool:
        return sys.stdout.isatty() and os.environ.get("NO_COLOR") is None

    @classmethod
    def codes(cls) -> dict[str, str]:
        if cls._on():
            return dict(B="\033[34m", G="\033[32m", Y="\033[33m", R="\033[31m",
                        D="\033[2m", BOLD="\033[1m", RESET="\033[0m")
        return dict(B="", G="", Y="", R="", D="", BOLD="", RESET="")

def _box(title: str, lines: list[str], width: int = 64) -> str:
    """Top-and-bottom box with a title; lines padded to width-4 of content."""
    c = _C.codes()
    # Top:    ╭─ TITLE ─...─╮     (visible width = width)
    # Body:   │ CONTENT      │    (1 + 1 + (width-4) + 1 + 1 = width)
    # Bottom: ╰─...─╯              (1 + (width-2) + 1 = width)
    dashes_top = max(0, width - 5 - len(title))
    top = "╭─ " + title + " " + "─" * dashes_top + "╮"
    bot = "╰" + "─" * (width - 2) + "╯"
    body = ["│ " + ln.ljust(width - 4) + " │" for ln in lines]
    return c["BOLD"] + "\n".join([top] + body + [bot]) + c["RESET"]

def _step(n: int, total: int, msg: str) -> str:
    c = _C.codes()
    return f"\n{c['BOLD']}[step {n}/{total}]{c['RESET']} {msg}"

def _ok(msg: str) -> str:
    c = _C.codes()
    return f"  {c['G']}✓{c['RESET']} {msg}"

def _arrow(msg: str) -> str:
    c = _C.codes()
    return f"  {c['B']}→{c['RESET']} {msg}"

def _warn(msg: str) -> str:
    c = _C.codes()
    return f"  {c['Y']}!{c['RESET']} {msg}"

def _err(msg: str) -> str:
    c = _C.codes()
    return f"  {c['R']}✗{c['RESET']} {msg}"

def _prompt(msg: str, default: str = "n") -> str:
    """Yes/no prompt. Returns 'y' or 'n'. Empty input or EOF → default."""
    suffix = "[Y/n]" if default == "y" else "[y/N]"
    while True:
        try:
            ans = input(f"  {msg} {suffix} ").strip().lower()
        except EOFError:
            print()
            return default
        if not ans:
            return default
        if ans in ("y", "yes"):
            return "y"
        if ans in ("n", "no"):
            return "n"
        print(_warn("please answer y or n"))

def _input(msg: str, default: str = "") -> str:
    suffix = f"[{default}]" if default else ""
    try:
        ans = input(f"  {msg} {suffix} ").strip()
    except EOFError:
        print()
        ans = ""
    return ans or default

# ---------------------------------------------------------------------------
# Wizard phase router (pure function — testable)

# Phases the wizard handles
PHASE_FRESH                  = "fresh"                  # not lifted, ready to lift
PHASE_PENDING_REBOOT         = "pending_reboot"         # lifted but not yet rebooted (impossible to detect cleanly; informational)
PHASE_LIFTED_PENDING_FINAL   = "lifted_pending_final"   # under Xen, show_menu_pending=True
PHASE_LIFTED_DONE            = "lifted_done"            # under Xen, finalized
PHASE_STUCK                  = "stuck"                  # state says lifted, but we're on bare metal
PHASE_BLOCKED                = "blocked"                # detect found blockers

def wizard_phase(state: "LiftState", running_under_xen: bool, blockers: list[str]) -> str:
    if blockers:
        return PHASE_BLOCKED
    if not state.lifted:
        return PHASE_FRESH
    if running_under_xen and state.show_menu_pending:
        return PHASE_LIFTED_PENDING_FINAL
    if running_under_xen and not state.show_menu_pending:
        return PHASE_LIFTED_DONE
    # state.lifted but not under Xen
    return PHASE_STUCK

# ---------------------------------------------------------------------------
# Logging

def setup_logging(quiet: bool = False) -> Path:
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    ts = time.strftime("%Y%m%dT%H%M%S")
    logfile = LOG_DIR / f"rotten-apple-{ts}.log"
    fmt = "%(asctime)s %(levelname)s %(message)s"
    handlers: list[logging.Handler] = [logging.FileHandler(logfile)]
    if not quiet:
        handlers.append(logging.StreamHandler(sys.stderr))
    logging.basicConfig(level=logging.INFO, format=fmt, handlers=handlers)
    return logfile

log = logging.getLogger("rotten-apple")

# ---------------------------------------------------------------------------
# Subprocess helpers

class ShellError(RuntimeError):
    pass

def run(cmd: list[str], *, check: bool = True, capture: bool = False,
        env: Optional[dict] = None) -> subprocess.CompletedProcess:
    log.info("exec: %s", " ".join(cmd))
    res = subprocess.run(
        cmd,
        check=False,
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.PIPE if capture else None,
        env=env,
    )
    if capture:
        if res.stdout: log.debug("stdout: %s", res.stdout.strip())
        if res.stderr: log.debug("stderr: %s", res.stderr.strip())
    if check and res.returncode != 0:
        raise ShellError(f"{cmd[0]} exited {res.returncode}: "
                         f"{(res.stderr or '').strip()}")
    return res

def out(cmd: list[str], *, check: bool = True) -> str:
    return run(cmd, check=check, capture=True).stdout or ""

def have(cmd: str) -> bool:
    return shutil.which(cmd) is not None

