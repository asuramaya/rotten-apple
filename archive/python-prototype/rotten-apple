def cmd_lift(args) -> int:
    # --dry-run is read-only; allow it without root.
    if not args.dry_run:
        require_root()
        setup_logging()

    d = detect()
    if d.blockers:
        log.error("blockers present; refusing to lift:")
        for b in d.blockers: log.error("  ! %s", b)
        for b in d.blockers: print(f"  ! {b}", file=sys.stderr)
        return 2

    state = load_state() if not args.dry_run else LiftState()
    if state.lifted:
        log.info("state file says already lifted on %s", state.lift_timestamp)
        if not args.yes:
            print("Already lifted (per state file). Use --yes to re-run.")
            return 0

    # Compute Xen cmdline. Aggressive features are opt-in.
    dom0_mem = args.dom0_mem
    dom0_vcpus = args.dom0_vcpus
    xen_cmdline = build_xen_cmdline(
        dom0_mem=dom0_mem, dom0_vcpus=dom0_vcpus,
        iommu_force=args.iommu_force,
        dom0_pvh=args.dom0_pvh,
        serial_console=args.serial_console,
    )

    # Confirmation
    print("rotten-apple lift plan")
    print("---------------------")
    print(f"  install Xen packages (try: {XEN_PACKAGE_SETS[0]})")
    print(f"  set Xen cmdline:  {xen_cmdline}")
    print(f"  default GRUB:     <Xen menuentry — discovered after install>")
    print(f"  bare-metal entry: preserved (always available via Shift at boot)")
    print(f"  backup of /etc/default/grub will be saved under {BACKUP_DIR}")
    if d.warnings:
        print()
        print("  warnings:")
        for w in d.warnings: print(f"    - {w}")
    print()
    if args.dry_run:
        print("--dry-run: no changes made.")
        return 0
    if not args.yes:
        ans = input("proceed? [y/N] ").strip().lower()
        if ans != "y":
            print("aborted.")
            return 1

    # 1) Backup. Includes initramfs files because update-initramfs overwrites
    #    the same file used by both Xen and bare-metal entries — if the
    #    regen produces a broken initramfs, BOTH boot paths fail. With a
    #    backup, unlift can restore the working initramfs.
    backup_targets: list[Path] = [GRUB_DEFAULTS, GRUB_CFG]
    if d.initramfs_path:
        backup_targets.append(Path(d.initramfs_path))
    # Also back up any other initramfs files in /boot for any kernel.
    for p in sorted(Path("/boot").glob("initrd.img-*")):
        if p.is_file() and p not in backup_targets:
            backup_targets.append(p)
    backup = backup_files(backup_targets)
    state.backup_dir = str(backup)
    state.grub_default_before = d.grub_default_raw
    save_state(state)

    # 2) Install Xen
    if not d.xen_already_installed:
        installed: list[str] = []
        last_err: Optional[Exception] = None
        for pkgs in XEN_PACKAGE_SETS:
            try:
                run(["apt-get", "update"])
                run(["apt-get", "install", "-y"] + pkgs,
                    env={**os.environ, "DEBIAN_FRONTEND": "noninteractive"})
                installed = pkgs
                break
            except ShellError as e:
                last_err = e
                log.warning("package set %s failed; trying next", pkgs)
        if not installed:
            log.error("could not install any Xen package set; last error: %s", last_err)
            return 3
        state.xen_packages_installed = installed
    else:
        log.info("xen packages already installed; skipping apt step")
        # Best-effort recover what was installed
        r = run(["dpkg", "-l"], capture=True, check=False)
        state.xen_packages_installed = [
            ln.split()[1] for ln in (r.stdout or "").splitlines()
            if ln.startswith("ii ") and "xen" in ln
        ]

    # 3) Regenerate initramfs so that xen-blkfront / xen-netfront / xen-pci
    #    are present when dom0 boots. Without this, the dom0 kernel's
    #    initramfs has only virtio drivers, which are useless under Xen
    #    (the PV layer re-presents disks via xen-blkfront), and dom0
    #    drops to a busybox prompt unable to find /. Idempotent.
    log.info("regenerating initramfs to include Xen PV modules")
    run(["update-initramfs", "-u", "-k", "all"],
        env={**os.environ, "DEBIAN_FRONTEND": "noninteractive"})

    # 3a) Sanity-check the new initramfs. If something went wrong with the
    #     regen (out of disk, build hook crashed, missing module dependency)
    #     the file may be missing, truncated, or wildly smaller than before.
    #     We catch that here and roll back rather than continue and find out
    #     at boot time.
    if d.initramfs_path:
        new_path = Path(d.initramfs_path)
        if not new_path.exists():
            log.error("initramfs vanished after update-initramfs; rolling back")
            shutil.copy2(backup / d.initramfs_path.lstrip("/"), new_path)
            return 6
        new_size_mb = new_path.stat().st_size // (1024 * 1024)
        if d.initramfs_size_mb > 5 and new_size_mb < d.initramfs_size_mb // 2:
            log.error(
                "initramfs shrank suspiciously (%d MB → %d MB); rolling back "
                "to avoid an unbootable kernel",
                d.initramfs_size_mb, new_size_mb,
            )
            shutil.copy2(backup / d.initramfs_path.lstrip("/"), new_path)
            return 6
        log.info("initramfs sanity OK (%d MB → %d MB)",
                 d.initramfs_size_mb, new_size_mb)

    # 4) First update-grub (without our default override) so that
    #    20_linux_xen has a chance to add a Xen menuentry.
    run(["update-grub"])

    # 4) Discover the Xen menuentry path from the freshly written grub.cfg.
    cfg_text = GRUB_CFG.read_text()
    xen_path = find_xen_path(cfg_text)
    if not xen_path:
        log.error("no Xen menuentry was generated by update-grub; aborting "
                  "without further changes. Bare-metal boot still works.")
        return 4
    log.info("xen menuentry path: %s", xen_path)
    state.xen_entry_title = xen_path.split(">")[-1]
    state.xen_default_path = xen_path

    # 5) Patch /etc/default/grub with our managed block, then update-grub again.
    text = GRUB_DEFAULTS.read_text()
    new_text = patch_grub_defaults(text, xen_cmdline, xen_path,
                                   show_menu=args.show_grub_menu,
                                   dom0_serial_console=args.serial_console)
    tmp = GRUB_DEFAULTS.with_suffix(".rotten-apple.tmp")
    tmp.write_text(new_text)
    os.replace(tmp, GRUB_DEFAULTS)
    log.info("patched %s", GRUB_DEFAULTS)
    state.show_menu_pending = args.show_grub_menu

    run(["update-grub"])

    # 6) Verify the new grub.cfg still contains our Xen entry AND the
    #    bare-metal entry. If either is missing, the system would boot
    #    only one option — losing the bare-metal fallback is catastrophic
    #    (no recovery without USB live media). Roll back if so.
    cfg_text = GRUB_CFG.read_text()
    titles = list_menuentries(cfg_text)
    has_xen = find_xen_path(cfg_text) is not None
    has_bare_metal = any(
        ("xen" not in t.lower() and "recovery" not in t.lower())
        for t in titles
    )
    if not has_xen or not has_bare_metal:
        log.error(
            "post-write grub.cfg is missing entries (xen=%s, bare-metal=%s); "
            "rolling back. Bare-metal Ubuntu booting is preserved.",
            has_xen, has_bare_metal,
        )
        shutil.copy2(backup / "etc/default/grub", GRUB_DEFAULTS)
        run(["update-grub"])
        return 5

    # 7) Install first-boot autostart (best-effort; not fatal if it fails).
    invoking_user = os.environ.get("SUDO_USER")
    if invoking_user and invoking_user != "root":
        installed_for = install_firstboot_autostart(invoking_user)
        state.firstboot_autostart_for = installed_for
    else:
        log.info("no SUDO_USER (or running as root directly); "
                 "skipping firstboot autostart install")

    # 8) Mark as lifted.
    state.lifted = True
    state.lift_timestamp = time.strftime("%Y-%m-%dT%H:%M:%S%z")
    save_state(state)

    print()
    print("lift complete.")
    print()
    print(f"  default boot entry  : {xen_path}")
    print(f"  bare-metal fallback : preserved (Shift at boot to access GRUB)")
    print(f"  state file          : {STATE_FILE}")
    print(f"  backup              : {backup}")
    if args.show_grub_menu:
        print(f"  GRUB menu           : visible for 5s on next boot "
              f"(run `rotten-apple finalize` to re-hide)")
    if state.firstboot_autostart_for:
        print(f"  firstboot notify    : installed for user "
              f"{state.firstboot_autostart_for}")
    print()
    print("reboot when ready. if the desktop fails to come up, hold Shift at")
    print("boot, choose the non-Xen Ubuntu entry, and run `sudo rotten-apple")
    print("unlift` to restore.")
    return 0

def cmd_unlift(args) -> int:
    require_root()
    setup_logging()
    state = load_state()
    if not state.lifted and not args.force:
        print("not lifted (per state). use --force to undo anyway.")
        return 0

    # Restore /etc/default/grub from the most recent backup, or strip our block.
    restored = False
    if state.backup_dir:
        bak = Path(state.backup_dir) / "etc/default/grub"
        if bak.exists():
            shutil.copy2(bak, GRUB_DEFAULTS)
            log.info("restored %s from %s", GRUB_DEFAULTS, bak)
            restored = True
    if not restored:
        # Fallback: strip our managed block.
        text = GRUB_DEFAULTS.read_text()
        GRUB_DEFAULTS.write_text(strip_managed_block(text))
        log.info("stripped rotten-apple block from %s", GRUB_DEFAULTS)

    # Restore initramfs files from backup if we have them. This guards
    # against a broken initramfs that update-initramfs produced during lift.
    # Even if lift's sanity check passed, the user might want to revert
    # for a different reason — restoring the original is always safe.
    if state.backup_dir:
        bak_boot = Path(state.backup_dir) / "boot"
        if bak_boot.exists():
            for bp in sorted(bak_boot.glob("initrd.img-*")):
                target = Path("/boot") / bp.name
                shutil.copy2(bp, target)
                log.info("restored initramfs %s", target)

    run(["update-grub"])

    if args.purge:
        pkgs = state.xen_packages_installed
        if pkgs:
            run(["apt-get", "remove", "--purge", "-y"] + pkgs,
                env={**os.environ, "DEBIAN_FRONTEND": "noninteractive"})
            run(["apt-get", "autoremove", "-y"])
        else:
            log.info("no recorded xen packages to purge")

    state.lifted = False
    state.lift_timestamp = None
    save_state(state)

    print()
    print("unlift complete. on next reboot, the bare-metal GRUB default is restored.")
    if not args.purge:
        print("xen packages remain installed. re-run with --purge to remove them.")
    return 0

def cmd_status(args) -> int:
    state = load_state()
    d = detect()
    print(f"rotten-apple v{VERSION}")
    print(f"  lifted (per state):  {state.lifted}")
    print(f"  lift timestamp:      {state.lift_timestamp}")
    print(f"  backup dir:          {state.backup_dir}")
    print(f"  xen entry title:     {state.xen_entry_title}")
    print(f"  xen packages:        {', '.join(state.xen_packages_installed) or '(none recorded)'}")
    print(f"  running under xen:   {d.running_under_xen}")
    print(f"  current GRUB_DEFAULT:{d.grub_default_raw}")
    return 0

def _format_mb(kb: int) -> str:
    """Pretty-print kB → 'NN.N GB' / 'NN MB'."""
    if kb >= 1024 * 1024:
        return f"{kb / (1024*1024):.1f} GB"
    return f"{kb // 1024} MB"

def cmd_wizard(args) -> int:
    """
    Single state-aware entry point. Detects which phase of the lift cycle the
    system is in and runs only the relevant interactive steps. Calling this
    repeatedly walks the user from fresh install → reboot → finalize → done.
    """
    d = detect()
    state = load_state()
    phase = wizard_phase(state, d.running_under_xen, d.blockers)

    print(_box("rotten-apple wizard",
               [f"version {VERSION}    phase: {phase}"]))

    match phase:
        case "blocked":          return _wizard_blocked(d)
        case "fresh":            return _wizard_fresh(args, d, state)
        case "lifted_pending_final": return _wizard_post_lift(args, d, state)
        case "lifted_done":      return _wizard_done(args, d, state)
        case "stuck":            return _wizard_stuck(args, d, state)
    return 2  # unreachable

def _wizard_blocked(d: "Detection") -> int:
    print(_step(1, 1, "system check"))
    for b in d.blockers:
        print(_err(b))
    return 2

def _wizard_done(args, d: "Detection", state: "LiftState") -> int:
    print(_step(1, 1, "lift state"))
    print(_ok("running as Xen dom0"))
    print(_ok(f"lifted on {state.lift_timestamp}"))
    print(_ok("GRUB menu hidden; future boots are seamless"))
    print()
    print("nothing to do. run `rotten-apple status` or `verify` to inspect.")
    return 0

def _wizard_stuck(args, d: "Detection", state: "LiftState") -> int:
    print(_step(1, 1, "diagnosis"))
    print(_warn("state file says lifted, but you are not running under Xen."))
    print(_warn(f"the recorded GRUB path was: {state.xen_default_path}"))
    print()
    print("  most common cause: GRUB picked the bare-metal entry on this boot.")
    print("  this can happen when:")
    print("    • you held Shift at boot and chose 'Ubuntu' (the non-Xen one)")
    print("    • a kernel upgrade renamed the Xen menuentry "
          "(`refresh` re-pins it)")
    print("    • GRUB_DEFAULT path doesn't match any current menuentry")
    print()
    if _prompt("re-pin the Xen entry now and reboot back into it?", "y") == "y":
        if os.geteuid() != 0:
            print(_err("must run as root for refresh"))
            print("  → re-run with: sudo ./rotten-apple wizard")
            return 1
        rc = cmd_refresh(argparse.Namespace())
        if rc == 0:
            print()
            print(_ok("default re-pinned. reboot when ready."))
        return rc
    if _prompt("alternatively, undo the lift entirely (`unlift`)?", "n") == "y":
        if os.geteuid() != 0:
            print(_err("must run as root for unlift"))
            print("  → re-run with: sudo ./rotten-apple wizard")
            return 1
        return cmd_unlift(argparse.Namespace(purge=False, force=False))
    print()
    print("nothing changed. you remain on bare metal.")
    return 0

def _wizard_post_lift(args, d: "Detection", state: "LiftState") -> int:
    """We are running under Xen and the GRUB menu is still in 5s-visible mode.
    Run verify, then offer to finalize."""
    print(_step(1, 2, "verifying lift"))
    rc = cmd_verify(argparse.Namespace())
    if rc != 0:
        print()
        print(_err("verification incomplete; finalize is risky until this is fixed."))
        print("  inspect the output above. common fixes:")
        print("    • `sudo systemctl start xenstored` if the service is down")
        print("    • check /var/log/rotten-apple/ for the lift log")
        return rc

    print(_step(2, 2, "finalize"))
    print("  the GRUB menu is currently visible for 5 s on every boot.")
    print("  finalize re-hides it so subsequent boots are silent and seamless.")
    print()
    if _prompt("re-hide the GRUB menu now?", "y") != "y":
        print()
        print("ok, leaving menu visible. run `rotten-apple finalize` when ready.")
        return 0
    if os.geteuid() != 0:
        print(_err("must run as root to finalize"))
        print("  → re-run with: sudo ./rotten-apple wizard")
        return 1
    rc = cmd_finalize(argparse.Namespace())
    if rc == 0:
        print()
        print(_box("done", [
            "lift verified, GRUB menu hidden, system steady.",
            "future boots will be indistinguishable from bare metal.",
            "",
            "next: `rotten-apple status` any time to confirm.",
        ]))
    return rc

def _wizard_fresh(args, d: "Detection", state: "LiftState") -> int:
    """Walk the user from bare-metal → ready-to-reboot lifted state."""
    # ---- step 1: system summary -----------------------------------------
    print(_step(1, 4, "inspecting your system"))
    print(f"  distro:           {d.distro_id} {d.distro_version}")
    print(f"  kernel:           {d.kernel}")
    print(f"  firmware:         {'UEFI' if d.is_uefi else 'BIOS'}, "
          f"Secure Boot {d.secure_boot}")
    print(f"  ram:              {_format_mb(d.mem_total_kb)}")
    print(f"  cpus:             {d.cpu_count}")
    iommu = "intel" if d.has_intel_iommu else ("amd" if d.has_amd_iommu else "?")
    print(f"  iommu:            {iommu} ({'enabled' if d.iommu_in_cmdline else 'not in cmdline'})")
    print(f"  nvidia driver:    {'proprietary' if d.nvidia_proprietary else 'open / not loaded'}")
    if d.warnings:
        print()
        for w in d.warnings:
            print(_warn(w))
    else:
        print(_ok("no warnings"))

    # ---- step 2: resource allocation ------------------------------------
    print(_step(2, 4, "resource allocation"))
    total_gb = d.mem_total_kb // (1024 * 1024)
    default_dom0_mem = "8G" if total_gb >= 16 else f"{max(2, total_gb // 4)}G"
    default_dom0_vcpus = str(min(8, max(2, d.cpu_count // 2)))
    print(f"  dom0 will own a fixed slice of host resources.")
    print(f"  whatever you give dom0, that much stays available to your")
    print(f"  Ubuntu desktop; the rest is reservable for guests later.")
    print()
    dom0_mem = _input("dom0 memory:", default_dom0_mem)
    dom0_vcpus = _input("dom0 vcpus:", default_dom0_vcpus)

    # ---- step 3: confirmation -------------------------------------------
    # Wizard uses safe defaults; advanced users invoke `lift` directly with
    # --iommu-force / --dom0-pvh.
    xen_cmdline = build_xen_cmdline(dom0_mem=dom0_mem, dom0_vcpus=dom0_vcpus)
    print(_step(3, 4, "confirmation"))
    print(f"  about to:")
    print(f"    + apt install xen-system-amd64        (~50 MB download)")
    print(f"    + add Xen menuentry to GRUB")
    print(f"    + set Xen as default boot")
    print(f"    + show GRUB menu briefly on first lifted boot (--show-grub-menu)")
    print(f"    + install login notification for first boot under Xen")
    print()
    print(f"  Xen cmdline:  {xen_cmdline}")
    print(f"  backup dir:   {BACKUP_DIR}/<timestamp>/")
    print()
    print("  this is fully reversible:")
    print("    sudo ./rotten-apple unlift            # restores bare-metal default")
    print("    Shift at boot                         # one-shot bare-metal pick")
    print()
    if _prompt("proceed with the lift?", "n") != "y":
        print()
        print("aborted. nothing changed.")
        return 1

    if os.geteuid() != 0:
        print()
        print(_err("must run as root to perform the lift."))
        print("  → re-run with: sudo ./rotten-apple wizard")
        return 1

    # ---- step 4: perform lift -------------------------------------------
    print(_step(4, 4, "performing lift"))

    lift_args = argparse.Namespace(
        dry_run=False, yes=True,
        dom0_mem=dom0_mem, dom0_vcpus=dom0_vcpus,
        show_grub_menu=True,
        iommu_force=False, dom0_pvh=False,
    )
    rc = cmd_lift(lift_args)
    if rc != 0:
        print()
        print(_err(f"lift failed (rc={rc}). bare-metal boot still works."))
        return rc

    # ---- post-lift summary ----------------------------------------------
    state = load_state()
    print()
    print(_box("ready to reboot", [
        "what you'll see on next boot:",
        "  1. UEFI POST                                (unchanged)",
        "  2. GRUB menu visible for 5 s                (← new, one-time)",
        "     • " + (state.xen_default_path or "Ubuntu, with Xen hypervisor")[:50],
        "     • Ubuntu                                  (bare-metal fallback)",
        "  3. ~1 s of Xen text-mode boot               (← new)",
        "  4. plymouth → GDM → your desktop            (unchanged)",
        "  5. tray notification: 'Lift verified'       (← new)",
        "",
        "after login, run `rotten-apple wizard` again to finalize",
        "(this re-hides the GRUB menu).",
        "",
        "if anything looks wrong: hold Shift, pick 'Ubuntu', then",
        "`sudo ./rotten-apple unlift`.",
    ], width=68))
    print()
    if _prompt("reboot now?", "n") == "y":
        print()
        print("rebooting in 3 seconds... (Ctrl-C to cancel)")
        try:
            time.sleep(3)
        except KeyboardInterrupt:
            print()
            print("cancelled. reboot manually with: sudo reboot")
            return 0
        run(["systemctl", "reboot"])
    else:
        print()
        print("ok. reboot manually when ready: sudo reboot")
    return 0

def cmd_verify(args) -> int:
    """Post-boot health check. Does not require root."""
    print(f"rotten-apple v{VERSION} — verify")
    print()

    proc_xen = Path("/proc/xen")
    proc_xen_caps = proc_xen / "capabilities"
    is_dom0 = False
    caps = ""
    if proc_xen_caps.exists():
        try:
            caps = proc_xen_caps.read_text().strip()
            is_dom0 = "control_d" in caps
        except Exception:
            pass

    print(f"  /proc/xen present:    {'yes' if proc_xen.is_dir() else 'no'}")
    print(f"  capabilities:         {caps or '(none)'}")
    print(f"  running as dom0:      {'yes' if is_dom0 else 'no'}")

    xl_ok = False
    xl_total_mb: Optional[int] = None
    if shutil.which("xl"):
        r = run(["xl", "info"], capture=True, check=False)
        xl_ok = r.returncode == 0
        if xl_ok and r.stdout:
            m = re.search(r"^total_memory\s*:\s*(\d+)", r.stdout, re.M)
            if m: xl_total_mb = int(m.group(1))
    print(f"  `xl info` works:      {'yes' if xl_ok else 'no'}"
          + (f"  (total {xl_total_mb} MB)" if xl_total_mb else ""))

    xenstored_ok = False
    if shutil.which("systemctl"):
        r = run(["systemctl", "is-active", "xenstored.service"],
                capture=True, check=False)
        xenstored_ok = (r.stdout or "").strip() == "active"
    print(f"  xenstored active:     {'yes' if xenstored_ok else 'no'}")

    state = load_state()
    print(f"  state file:           lifted={state.lifted}, "
          f"ts={state.lift_timestamp}")
    print(f"  recorded xen path:    {state.xen_default_path}")

    print()
    if is_dom0 and xl_ok and xenstored_ok:
        print("verify: PASS — system is correctly running under Xen as dom0.")
        return 0
    if state.lifted and not is_dom0:
        print("verify: FAIL — state says lifted but we are not running under Xen.")
        print("       likely cause: GRUB picked the bare-metal entry. Run")
        print("       `sudo rotten-apple refresh` and reboot, or check that")
        print("       GRUB_DEFAULT in /etc/default/grub matches an entry in")
        print("       /boot/grub/grub.cfg.")
        return 1
    if not state.lifted:
        print("verify: not lifted (per state file).")
        return 0
    print("verify: PARTIAL — under Xen but support services have issues.")
    return 1

def cmd_finalize(args) -> int:
    """Re-hide the GRUB menu after a `--show-grub-menu` first boot."""
    require_root()
    setup_logging()
    state = load_state()
    if not state.lifted:
        print("not lifted; nothing to finalize.")
        return 0
    if not state.show_menu_pending:
        print("nothing pending; GRUB menu visibility already matches user defaults.")
        return 0

    text = GRUB_DEFAULTS.read_text()
    xen_cmdline_match = re.search(r'GRUB_CMDLINE_XEN_DEFAULT="([^"]*)"', text)
    xen_cmdline = (xen_cmdline_match.group(1) if xen_cmdline_match
                   else build_xen_cmdline(dom0_mem="8G", dom0_vcpus="8"))
    path = state.xen_default_path or state.xen_entry_title
    if not path:
        log.error("no recorded xen path in state; refusing to rewrite block")
        return 4

    new_text = patch_grub_defaults(text, xen_cmdline, path, show_menu=False)
    GRUB_DEFAULTS.write_text(new_text)
    run(["update-grub"])

    state.show_menu_pending = False
    save_state(state)
    print("finalized: GRUB menu hidden again on next boot.")
    return 0

def cmd_refresh(args) -> int:
    """After a kernel upgrade, the Xen menuentry path may change.
    Re-discover the path and re-pin GRUB_DEFAULT."""
    require_root()
    setup_logging()
    state = load_state()
    if not state.lifted:
        print("not lifted; nothing to refresh.")
        return 0

    cfg_text = GRUB_CFG.read_text()
    path = find_xen_path(cfg_text)
    if not path:
        log.error("no Xen menuentry found in grub.cfg; refusing to change defaults")
        return 4
    if path == state.xen_default_path:
        print(f"unchanged: {path}")
        return 0

    text = GRUB_DEFAULTS.read_text()
    stripped = strip_managed_block(text)
    xen_cmdline_match = re.search(r'GRUB_CMDLINE_XEN_DEFAULT="([^"]*)"', text)
    xen_cmdline = (xen_cmdline_match.group(1) if xen_cmdline_match
                   else build_xen_cmdline(dom0_mem="8G", dom0_vcpus="8"))
    new_text = patch_grub_defaults(stripped, xen_cmdline, path,
                                   show_menu=state.show_menu_pending)
    GRUB_DEFAULTS.write_text(new_text)
    run(["update-grub"])

    state.xen_default_path = path
    state.xen_entry_title = path.split(">")[-1]
    save_state(state)
    print(f"re-pinned default to: {path}")
    return 0

# ---------------------------------------------------------------------------
# CLI

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="rotten-apple", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("--version", action="version", version=VERSION)
    sub = p.add_subparsers(dest="command", required=False)

    sub.add_parser("wizard", help="(default) interactive guided lift cycle")
    sub.add_parser("detect", help="inspect host; print readiness report")

    sp = sub.add_parser("lift", help="install Xen, add hypervisor GRUB entry, set default")
    sp.add_argument("--dry-run", action="store_true", help="plan only; make no changes")
    sp.add_argument("--yes", "-y", action="store_true", help="skip confirmation")
    sp.add_argument("--dom0-mem", default="8G",
                    help="memory to give dom0 (default: 8G)")
    sp.add_argument("--dom0-vcpus", default="8",
                    help="vcpus to give dom0 (default: 8)")
    sp.add_argument("--show-grub-menu", action="store_true",
                    help="reveal the GRUB menu for 5s on next boot so you can "
                         "visually confirm both entries (run `finalize` after)")
    sp.add_argument("--iommu-force", action="store_true",
                    help="set iommu=force,strict (real-hardware passthrough; "
                         "panics on hosts without working IOMMU)")
    sp.add_argument("--dom0-pvh", action="store_true",
                    help="set dom0=pvh (modern fast dom0 mode; needs PVH-on-VMX "
                         "support, often missing in nested KVM)")
    sp.add_argument("--serial-console", action="store_true",
                    help="route Xen + dom0 console output to com1/ttyS0; "
                         "essential for nested-VM debugging where there is no VGA")

    sub.add_parser("verify",
                   help="post-boot health check; confirm we are running as dom0")

    sub.add_parser("finalize",
                   help="re-hide the GRUB menu after a --show-grub-menu boot")

    sp = sub.add_parser("unlift", help="restore bare-metal default")
    sp.add_argument("--purge", action="store_true",
                    help="also apt-remove --purge the Xen packages we installed")
    sp.add_argument("--force", action="store_true",
                    help="undo even if state file does not say we lifted")

    sub.add_parser("status", help="print current lift state")
    sub.add_parser("refresh",
                   help="re-pin Xen default after kernel upgrade changed its path")
    return p

def main(argv: Optional[list[str]] = None) -> int:
    args = build_parser().parse_args(argv)
    if args.command is None:
        args.command = "wizard"
    match args.command:
        case "wizard":   return cmd_wizard(args)
        case "detect":   return cmd_detect(args)
        case "lift":     return cmd_lift(args)
        case "verify":   return cmd_verify(args)
        case "finalize": return cmd_finalize(args)
        case "unlift":   return cmd_unlift(args)
        case "status":   return cmd_status(args)
        case "refresh":  return cmd_refresh(args)
    return 2  # unreachable

if __name__ == "__main__":
    sys.exit(main())
